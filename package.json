{
  "name": "radical-browser-desktop",
  "version": "0.3.10",
  "description": "The browser built for builders.",
  "author": "The Radical Party",
  "private": true,
  "main": "build/main/index.js",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs && electron .",
    "start": "electron .",
    "dist": "node build.mjs && electron-builder --mac --publish never",
    "dist:all": "node build.mjs && electron-builder --mac --linux --win --publish never"
  },
  "build": {
    "appId": "com.radicalbrowser.desktop",
    "productName": "Radical Browser",
    "copyright": "Copyright © 2025 Radical Browser",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Radical Browser",
      "icon": "assets/icon.icns",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "build/**/*",
      "assets/icon.*",
      "node_modules/electron/**/*"
    ],
    "extraFiles": [],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
